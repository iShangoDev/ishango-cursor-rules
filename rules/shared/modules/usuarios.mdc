```
src/
├── components/usuarios/
│   ├── usuarios.types.ts
│   ├── usuarios-view.tsx           ← puedeHacer(), fetch desde /api/usuarios/
│   ├── usuarios-table.tsx          ← columnas: nombre, email, estado Chip, acciones
│   ├── usuario-form.tsx            ← campos por modo: crear (email+password+nombre) / editar (nombre+activo)
│   ├── usuario-crear-modal.tsx
│   ├── usuario-editar-modal.tsx
│   ├── usuario-detail-view.tsx     ← detalle con tab de roles
│   ├── usuario-roles-table.tsx     ← roles asignados + botón quitar
│   ├── asignar-rol-modal.tsx       ← select módulo → select rol → asignar
│   └── use-usuarios.ts             ← mutations: createUsuario, updateUsuario + usuario-roles
