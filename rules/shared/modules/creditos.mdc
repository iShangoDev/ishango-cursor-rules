│   ├── credito-editar-modal.tsx       ← modal editar
│   ├── imputar-view.tsx               ← wizard imputar CSV (upload → preview → confirm → resultado)
│   ├── creditos.types.ts              ← tipos TS (espejo Motor)
│   ├── creditos-query-key.ts          ← query keys (evitar dependencia circular con use-creditos)
│   └── use-creditos.ts                ← mutations BFF
